# ═══════════════════════════════════════════════════════════
# reBorn_i — Production Environment (Render)
# Copy ALL of these into Render → Environment tab
# ═══════════════════════════════════════════════════════════

# ── System (REQUIRED) ────────────────────────────────────
PYTHON_VERSION=3.10.12
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── Application ──────────────────────────────────────────
APP_NAME=reBorn_i
APP_VERSION=1.0.0

# ── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=*

# ── Database (REPLACE with your Render Postgres Internal URL) ──
# Go to Render Dashboard → your PostgreSQL → copy "Internal Database URL"
# Then change postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST/YOUR_DB_NAME
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── JWT Authentication ───────────────────────────────────
JWT_SECRET_KEY=0piJQ5lSmbGLFqBUz_dHuiaXp4TXjphXJLvJnem4hQNRVpJLrvRjm0iMUAZU7ZpvcOMPVI0YH5JJ-_KQDU7VtQ
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=253052508803-hh2u37u4udhvjkge92ibh2nbrr75i3ou.apps.googleusercontent.com

# ── OpenAI / LLM (optional — system works without it) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# ── Embedding ────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_CACHE_TTL=3600
EMBEDDING_TIMEOUT=5

# ── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf

# ── Scoring Weights ─────────────────────────────────────
WEIGHT_SKILL_MATCH=0.35
WEIGHT_EXPERIENCE_ALIGNMENT=0.25
WEIGHT_KEYWORD_DENSITY=0.20
WEIGHT_EMBEDDING_SIMILARITY=0.20

# ── Market Radar ─────────────────────────────────────────
MARKET_DATA_PATH=data/job_market_dataset.json
MARKET_REFRESH_INTERVAL_HOURS=24

# ── Razorpay Payment (REQUIRED for payment flow) ────────
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# ── Frontend URL (REQUIRED for CORS and redirects) ──────
FRONTEND_URL=https://YOUR_VERCEL_FRONTEND_URL
