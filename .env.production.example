# reBorn_i Backend — Production Environment Variables
# For Railway / Render Deployment

# ── Application ──────────────────────────────────────────
APP_NAME=reBorn_i
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# ── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
# UPDATE THIS: Your frontend Vercel URL
CORS_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# ── Database ─────────────────────────────────────────────
# Railway Postgres: Copy from Railway Variables tab
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────
# Optional: if using Redis, add connection string
REDIS_URL=

# ── JWT Authentication ───────────────────────────────────
# KEEP YOUR SAME SECRET (from local .env) to avoid invalidating tokens
JWT_SECRET_KEY=0piJQ5lSmbGLFqBUz_dHuiaXp4TXjphXJLvJnem4hQNRVpJLrvRjm0iMUAZU7ZpvcOMPVI0YH5JJ-_KQDU7VtQ
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth ──────────────────────────────────────
# Must be the SAME as frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=253052508803-hh2u37u4udhvjkge92ibh2nbrr75i3ou.apps.googleusercontent.com

# ── OpenAI / LLM ────────────────────────────────────────
# Add your OpenAI API key if you want LLM-powered features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# ── Embedding Model ─────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_TTL=3600

# ── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf

# ── Scoring Weights ─────────────────────────────────────
WEIGHT_SKILL_MATCH=0.35
WEIGHT_EXPERIENCE_ALIGNMENT=0.25
WEIGHT_KEYWORD_DENSITY=0.20
WEIGHT_EMBEDDING_SIMILARITY=0.20

# ── Market Radar ─────────────────────────────────────────
# Path to job market dataset
MARKET_DATA_PATH=data/job_market_dataset.json
MARKET_REFRESH_INTERVAL_HOURS=24
