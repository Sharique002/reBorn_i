# ═══════════════════════════════════════════════════════════
# reBorn_i — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for production.
# Variables with defaults can be left commented out.
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
APP_NAME=reBorn_i
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development

# ── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
# Comma-separated origins, or * for all
CORS_ORIGINS=*

# ── Database [REQUIRED] ─────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://reborn:reborn@localhost:5432/reborn_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication [REQUIRED in production] ─────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth [OPTIONAL for Google Sign-In] ──────────
# Create OAuth client at https://console.cloud.google.com/apis/credentials
# See GOOGLE_OAUTH_SETUP.md for detailed setup instructions
GOOGLE_CLIENT_ID=

# ── OpenAI / LLM [REQUIRED for explanation features] ────
# Only used for explanation-layer calls; scoring is deterministic.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# ── Embedding Model ─────────────────────────────────────
# sentence-transformers model name (downloaded automatically)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_TTL=3600

# ── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf

# ── Scoring Weights (deterministic, must sum to 1.0) ────
WEIGHT_SKILL_MATCH=0.35
WEIGHT_EXPERIENCE_ALIGNMENT=0.25
WEIGHT_KEYWORD_DENSITY=0.20
WEIGHT_EMBEDDING_SIMILARITY=0.20

# ── Market Radar ─────────────────────────────────────────
MARKET_DATA_PATH=data/job_market_dataset.json
MARKET_REFRESH_INTERVAL_HOURS=24
