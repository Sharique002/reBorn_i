# ═══════════════════════════════════════════════════════════
# reBorn_i Frontend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env in the frontend/ directory:
#   cd frontend
#   cp .env.example .env
#
# Then add your Google OAuth Client ID below.
# See ../GOOGLE_OAUTH_SETUP.md for detailed setup instructions.
# ═══════════════════════════════════════════════════════════

# Google OAuth Client ID (get from https://console.cloud.google.com/apis/credentials)
# Must be the SAME client ID as GOOGLE_CLIENT_ID in backend .env
# Format: numbers-randomstring.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=

# Backend API URL (for production deployment)
# Example: https://reborn-backend.railway.app
# Leave empty for local development (uses relative /api/v1)
VITE_API_URL=
